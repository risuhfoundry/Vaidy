NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/llama-3.1-nemotron-nano-vl-8b-v1
NVIDIA_FALLBACK_MODEL=
NVIDIA_TIMEOUT_SECONDS=45
NVIDIA_TEXT_TIMEOUT_SECONDS=60
NVIDIA_MAX_TOKENS=700
NVIDIA_TEXT_MAX_TOKENS=1800
NIM_PAGE_SLEEP_SECONDS=0
NIM_RETRY_ATTEMPTS=3
NIM_RETRY_BACKOFF_SECONDS=5

VAIDY_AGENT_DATABASE_PATH=storage/health_agent.db
VAIDY_AGENT_REPORTS_DIR=storage/reports
VAIDY_AGENT_OUTPUT_DIR=outputs
VAIDY_EMBEDDINGS_LOCAL_PRIMARY=true
VAIDY_ONNX_MODEL_REPO=Xenova/all-MiniLM-L6-v2
VAIDY_ONNX_MODEL_FILE=onnx/model.onnx
VAIDY_ONNX_TOKENIZER_FILE=tokenizer.json
VAIDY_ONNX_CACHE_DIR=storage/onnx_models
VAIDY_EMBEDDING_DIM=384
VAIDY_EMBEDDING_MAX_TOKENS=256
NVIDIA_EMBEDDING_MODEL=nvidia/nv-embed-v1
VAIDY_EMBEDDING_TIMEOUT_SECONDS=12
VAIDY_AGENT_SEARCH_LIMIT=5
